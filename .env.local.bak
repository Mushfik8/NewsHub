# ============================================================
# NewsHub BD — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to Git!

# ── Database ────────────────────────────────────────────────
# Local development: leave TURSO vars empty to use local SQLite (prisma/dev.db)
# Production (Turso): fill in your Turso connection details
TURSO_DATABASE_URL="libsql://newshub-mushfik8.aws-ap-south-1.turso.io"
TURSO_AUTH_TOKEN=""

# Legacy (used by old config — kept for reference, no longer needed by Prisma v7)
# DATABASE_URL="file:./prisma/dev.db"

# ── Security ─────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
CRON_SECRET="your-super-secret-cron-key-change-this-in-production"

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
