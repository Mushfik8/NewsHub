# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Security
JWT_SECRET=change-this-to-a-long-random-secret
CRON_SECRET=change-this-to-a-second-random-secret

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=System Admin

# Database
# Leave these empty locally to use ./data/news.db
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# Backward-compatible aliases
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional analytics
NEXT_PUBLIC_GA_ID=

# Optional Google AdSense
# Easiest: set only NEXT_PUBLIC_ADSENSE_CLIENT and enable Auto ads in AdSense
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
# Optional manual slot IDs for fixed placements
NEXT_PUBLIC_ADSENSE_SLOT=1234567890
NEXT_PUBLIC_ADSENSE_SLOT_BANNER=
NEXT_PUBLIC_ADSENSE_SLOT_RECTANGLE=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
