// Prisma v7 schema — URL has moved to prisma.config.ts
// Only provider is set here; url is NOT included (Prisma v7 change)

datasource db {
  provider = "sqlite"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  hashedPassword String
  name           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Article {
  id           String   @id @default(uuid())
  title        String
  slug         String   @unique
  source       String
  sourceSlug   String
  sourceUrl    String
  originalLink String
  publishedAt  DateTime
  image        String?
  category     String
  description  String
  urlHash      String   @unique
  views        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([publishedAt])
  @@index([sourceSlug])
  @@index([category])
}

model Source {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  feedUrl         String
  siteUrl         String
  defaultCategory String
  language        String   @default("bn")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model FetchLog {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  totalNew  Int
  errors    Int      @default(0)
  results   String
}
